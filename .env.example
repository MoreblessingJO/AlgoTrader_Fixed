# ═══════════════════════════════════════════
#  Trading System — Environment Variables
#  Copy to .env and fill in your values
# ═══════════════════════════════════════════

# ── Binance (Crypto) ─────────────────────────
BINANCE_API_KEY=your_binance_api_key
BINANCE_SECRET=your_binance_secret
BINANCE_TESTNET=true          # set false for live

# ── Deriv (Crash & Boom) ─────────────────────
DERIV_APP_ID=1089             # get free at developers.deriv.com
DERIV_API_TOKEN=your_deriv_token

# ── OANDA (Forex) ────────────────────────────
OANDA_API_KEY=your_oanda_practice_key
OANDA_ACCOUNT_ID=your_oanda_account_id
OANDA_ENVIRONMENT=practice    # practice | live

# ── Database ─────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=trading_system
POSTGRES_USER=trader
POSTGRES_PASSWORD=changeme

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Telegram alerts ──────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ── System ───────────────────────────────────
MODE=paper                    # paper | live
LOG_LEVEL=INFO
DASHBOARD_PORT=8080
